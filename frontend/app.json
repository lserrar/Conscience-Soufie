{
  "expo": {
    "name": "Conscience Soufie",
    "slug": "conscience-soufie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "consciencesoufie",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSMicrophoneUsageDescription": "Cette application n'utilise pas le microphone."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1c679f"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.FOREGROUND_SERVICE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1c679f"
        }
      ],
      "expo-font",
      "expo-notifications",
      [
        "expo-av",
        {
          "microphonePermission": "Cette application n'utilise pas le microphone."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
