{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "bundleIdentifier": "org.consciencesoufie.app"
      },
      "android": {
        "buildType": "apk",
        "package": "org.consciencesoufie.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "bundleIdentifier": "org.consciencesoufie.app"
      },
      "android": {
        "buildType": "apk",
        "package": "org.consciencesoufie.app"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m-medium",
        "bundleIdentifier": "org.consciencesoufie.app"
      },
      "android": {
        "buildType": "app-bundle",
        "package": "org.consciencesoufie.app"
      }
    }
  }
}
